# Same DB name as pharmacy-delivery-payment so Med API complaints sync to Admin GET /complaints.
MONGO_URI=mongodb://127.0.0.1:27017/pharmacy-system
PORT=5002
NODE_ENV=development
APP_URL=http://localhost:5000
JWT_ACCESS_SECRET=replace_with_access_secret
JWT_REFRESH_SECRET=replace_with_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# --- Email (set Resend OR SMTP; Resend wins when RESEND_API_KEY is set)
# Dashboard: https://resend.com — HTTPS; avoids SMTP port/firewall issues.
RESEND_API_KEY=
# Verified sender/domain in Resend (sandbox example below).
# Sandbox: recipient addresses may need to match your account / verified domain — see Resend dashboard → Logs if sends fail.
RESEND_FROM=MED-CARE Ethiopia <onboarding@resend.dev>

SMTP_USER=
SMTP_PASS=
SMTP_HOST=
SMTP_PORT=
SMTP_FROM=MED-CARE Ethiopia <noreply@medcare-et.com>


SUPER_ADMIN_EMAIL=superadmin@medcare-et.com
SUPER_ADMIN_PASSWORD=change_me_please
