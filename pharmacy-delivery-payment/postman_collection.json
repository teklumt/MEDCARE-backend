              "raw": "{{base_url}}/inventory?status=available&page=1&limit=20",
              "host": ["{{base_url}}"],
              "path": ["inventory"],
              "query": [
                {
                  "key": "status",
                  "value": "available",
                  "description": "available, out_of_stock, low_stock, expiring_soon"
                },
                {
                  "key": "category",
                  "value": "antibiotic",
                  "disabled": true
                },
                {
                  "key": "search",
                  "value": "amox",
                  "disabled": true
                },
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "20"
                }
              ]
