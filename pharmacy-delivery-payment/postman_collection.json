            "body": {
              "mode": "raw",
              "raw": "{\n  \"medicationId\": \"{{medication_id}}\",\n  \"nameEnglish\": \"Amoxicillin\",\n  \"nameAmharic\": \"አሞክሲሲሊን\",\n  \"genericName\": \"Amoxicillin\",\n  \"dosageStrength\": \"500mg\",\n  \"dosageForm\": \"tablet\",\n  \"category\": \"antibiotic\",\n  \"requiresPrescription\": true,\n  \"quantity\": 200,\n  \"price\": 45.50,\n  \"expiryDate\": \"2025-12-31\",\n  \"batchNumber\": \"BATCH-2024-001\",\n  \"supplierName\": \"PharmaCorp\",\n  \"lowThreshold\": 20\n}"
            },
