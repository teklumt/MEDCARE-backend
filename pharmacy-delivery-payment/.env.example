# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=5000
NODE_ENV=development

# ============================================
# DATABASE CONFIGURATION
# ============================================
# MongoDB Atlas connection string (already configured)
# Database name: pharmacy-system
MONGODB_URI=mongodb+srv://finalyeardb:zeERp4eDu5irxjtT@cluster0.0rftqvq.mongodb.net/pharmacy-system?retryWrites=true&w=majority&appName=Cluster0

# ============================================
# CLOUDINARY CONFIGURATION
# ============================================
# Get these from: https://cloudinary.com/console
# 1. Sign up/login to Cloudinary
# 2. Go to Dashboard
# 3. Copy Cloud Name, API Key, and API Secret

CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here

# ============================================
# JWT AUTHENTICATION
# ============================================
# Generate secure random strings for production
# Example: openssl rand -base64 32

JWT_SECRET=pharmacy_jwt_secret_2024_change_in_production
JWT_REFRESH_SECRET=pharmacy_refresh_secret_2024_change_in_production
JWT_EXPIRE=24h
JWT_REFRESH_EXPIRE=7d

# ============================================
# ENCRYPTION (for end-to-end chat encryption)
# ============================================
# Must be exactly 32 bytes for AES-256
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=change_this_to_32_byte_key_prod

# ============================================
# SMS/NOTIFICATION (optional - for future use)
# ============================================
SMS_API_KEY=your_sms_api_key
SMS_SENDER_ID=your_sender_id

# ============================================
# RATE LIMITING (optional)
# ============================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# FILE UPLOAD LIMITS
# ============================================
MAX_FILE_SIZE_MB=5
MAX_CSV_SIZE_MB=10

# ============================================
# CHAPA PAYMENT GATEWAY
# ============================================
# Get these from: https://dashboard.chapa.co
# Test credentials for development
# Live credentials for production

CHAPA_SECRET_KEY=CHASECK_TEST-your_secret_key_here
CHAPA_PUBLIC_KEY=CHAPUBK_TEST-your_public_key_here
CHAPA_WEBHOOK_SECRET=your_webhook_secret_here
CHAPA_MODE=test
# Change to 'live' for production

# Callback URLs
CHAPA_CALLBACK_URL=http://localhost:5000/api/v1/payments/chapa/webhook
FRONTEND_URL=http://localhost:3000
