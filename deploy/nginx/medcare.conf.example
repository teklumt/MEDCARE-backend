# MED-CARE Ethiopia — Nginx reverse proxy (example)
# Droplet IP: 64.227.2.138
# Docker Compose host ports: admin 5000→5002, pharmacy 5001→5000
#
# Install: sudo cp medcare.conf.example /etc/nginx/sites-available/medcare
#          sudo ln -s /etc/nginx/sites-available/medcare /etc/nginx/sites-enabled/
#          sudo nginx -t && sudo systemctl reload nginx

# Admin API — https://admin.64.227.2.138.nip.io
# Routes in app: /health, /api/admin/*
server {
    listen 80;
    server_name admin.64.227.2.138.nip.io;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name admin.64.227.2.138.nip.io;

    # Replace with certbot paths after: sudo certbot --nginx -d admin.64.227.2.138.nip.io
    ssl_certificate     /etc/letsencrypt/live/admin.64.227.2.138.nip.io/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/admin.64.227.2.138.nip.io/privkey.pem;

    client_max_body_size 10M;

    location / {
        proxy_pass http://127.0.0.1:5000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}

# Med API — https://pharmacy.64.227.2.138.nip.io
# Routes in app: /health, /api/v1/*
server {
    listen 80;
    server_name pharmacy.64.227.2.138.nip.io;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name pharmacy.64.227.2.138.nip.io;

    ssl_certificate     /etc/letsencrypt/live/pharmacy.64.227.2.138.nip.io/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/pharmacy.64.227.2.138.nip.io/privkey.pem;

    client_max_body_size 15M;

    location / {
        proxy_pass http://127.0.0.1:5001;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
